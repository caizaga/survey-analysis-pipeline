# Variables de entorno necesarias para correr el pipeline completo.
# Copia este archivo como .env y completa los valores.

# ID del Google Spreadsheet de destino (donde se suben los datos procesados).
# Lo encuentras en la URL: docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/
SHEETS_OUTPUT_ID=TU_SPREADSHEET_ID_DESTINO
